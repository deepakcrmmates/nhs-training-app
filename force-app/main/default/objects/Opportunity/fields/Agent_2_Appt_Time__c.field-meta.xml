<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Agent_2_Appt_Time__c</fullName>
    <externalId>false</externalId>
    <formula>IF(ISBLANK(Agent_2_Appointment__c), "",
IF(VALUE(MID(TEXT(Agent_2_Appointment__c), 12, 2)) = 0, "12",
IF(VALUE(MID(TEXT(Agent_2_Appointment__c), 12, 2)) &gt; 12,
TEXT(VALUE(MID(TEXT(Agent_2_Appointment__c), 12, 2)) - 12),
MID(TEXT(Agent_2_Appointment__c), 12, 2))) &amp;
":" &amp; MID(TEXT(Agent_2_Appointment__c), 15, 2) &amp;
IF(VALUE(MID(TEXT(Agent_2_Appointment__c), 12, 2)) &gt;= 12, " pm", " am"))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Agent 2 Appt Time</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
