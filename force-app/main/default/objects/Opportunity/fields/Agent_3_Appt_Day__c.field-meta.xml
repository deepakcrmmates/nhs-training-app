<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Agent_3_Appt_Day__c</fullName>
    <externalId>false</externalId>
    <formula>IF(ISBLANK(Agent_3_Appointment__c), "",
CASE(MOD(DATEVALUE(Agent_3_Appointment__c) - DATE(1900, 1, 7), 7),
0, "Sunday", 1, "Monday", 2, "Tuesday", 3, "Wednesday",
4, "Thursday", 5, "Friday", 6, "Saturday", ""))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Agent 3 Appt Day</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
