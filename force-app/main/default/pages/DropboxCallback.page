<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false">
<html>
<head>
<style>
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #F7F8F6; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
.card { background: #fff; border-radius: 10px; padding: 40px; text-align: center; box-shadow: 0 4px 24px rgba(0,0,0,0.1); max-width: 440px; }
.icon { font-size: 48px; margin-bottom: 16px; }
h2 { color: #2C5F2E; font-size: 20px; margin: 0 0 8px; }
p { color: #6B8A6B; font-size: 14px; margin: 0 0 20px; }
.code-box { background: #EAF4EF; border: 1px solid #C5DCCC; border-radius: 6px; padding: 12px; font-family: monospace; font-size: 12px; color: #1A2E1A; word-break: break-all; margin-bottom: 16px; }
.btn { padding: 10px 24px; background: #3A7D44; color: #fff; border: none; border-radius: 6px; font-size: 13px; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 0.04em; }
.btn:hover { background: #2C5F2E; }
.error { color: #DC2626; }
.note { font-size: 11px; color: #9AB09A; margin-top: 12px; }
</style>
</head>
<body>
<div class="card" id="card">
    <div class="icon">&#9989;</div>
    <h2 id="title">Connecting to Dropbox...</h2>
    <p id="msg">Processing authorization...</p>
    <div class="code-box" id="codeBox" style="display:none"></div>
    <button class="btn" id="copyBtn" style="display:none" onclick="copyCode()">Copy Auth Code</button>
    <div class="note" id="note" style="display:none">Copy this code and paste it in the Dropbox Setup page in Salesforce.</div>
</div>
<script>
    var params = new URLSearchParams(window.location.search);
    var code = params.get('code');
    var error = params.get('error');

    if (error) {
        document.getElementById('icon').textContent = '❌';
        document.getElementById('title').textContent = 'Authorization Failed';
        document.getElementById('msg').innerHTML = '<span class="error">Error: ' + error + '</span>';
    } else if (code) {
        document.getElementById('title').textContent = 'Dropbox Connected!';
        document.getElementById('msg').textContent = 'Authorization code received. Copy it below:';
        document.getElementById('codeBox').textContent = code;
        document.getElementById('codeBox').style.display = 'block';
        document.getElementById('copyBtn').style.display = 'inline-block';
        document.getElementById('note').style.display = 'block';

        // Also try to post back to opener
        if (window.opener) {
            window.opener.postMessage({ type: 'DROPBOX_AUTH_CODE', code: code }, '*');
            document.getElementById('note').textContent = 'Code sent to setup page. You can close this window.';
        }
    } else {
        document.getElementById('title').textContent = 'No Authorization Code';
        document.getElementById('msg').textContent = 'No code was returned from Dropbox.';
    }

    function copyCode() {
        navigator.clipboard.writeText(code).then(function() {
            document.getElementById('copyBtn').textContent = 'Copied!';
            setTimeout(function() { document.getElementById('copyBtn').textContent = 'Copy Auth Code'; }, 2000);
        });
    }
</script>
</body>
</html>
</apex:page>
