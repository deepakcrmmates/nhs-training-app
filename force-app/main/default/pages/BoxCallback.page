<apex:page showHeader="false" sidebar="false" standardStylesheets="false">
<html>
<head>
    <title>Box Authorization</title>
    <style>
        body { font-family: 'Aptos', 'Segoe UI', Arial, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #F2F7F5; }
        .card { background: #fff; border-radius: 12px; padding: 40px; text-align: center; box-shadow: 0 4px 24px rgba(0,0,0,0.1); max-width: 500px; }
        h2 { color: #0061D5; margin: 0 0 12px; font-size: 20px; }
        p { color: #374151; font-size: 14px; line-height: 1.6; margin: 0 0 16px; }
        .code { background: #f3f4f6; border: 1px solid #d1d5db; border-radius: 6px; padding: 12px; font-family: monospace; font-size: 12px; word-break: break-all; margin: 16px 0; color: #1f2937; }
        .success { color: #16a34a; font-weight: 700; }
        .error { color: #dc2626; font-weight: 700; }
    </style>
</head>
<body>
    <div class="card">
        <h2>Box Authorization</h2>
        <apex:outputPanel rendered="{!NOT(ISBLANK($CurrentPage.parameters.code))}">
            <p class="success">Authorization successful!</p>
            <p>Copy this code and paste it into the Box Setup page:</p>
            <div class="code">{!$CurrentPage.parameters.code}</div>
            <p>You can close this window now.</p>
        </apex:outputPanel>
        <apex:outputPanel rendered="{!NOT(ISBLANK($CurrentPage.parameters.error))}">
            <p class="error">Authorization failed</p>
            <p>Error: {!$CurrentPage.parameters.error}</p>
            <p>{!$CurrentPage.parameters.error_description}</p>
        </apex:outputPanel>
        <apex:outputPanel rendered="{!AND(ISBLANK($CurrentPage.parameters.code), ISBLANK($CurrentPage.parameters.error))}">
            <p>Waiting for authorization...</p>
        </apex:outputPanel>
    </div>
</body>
</html>
</apex:page>
