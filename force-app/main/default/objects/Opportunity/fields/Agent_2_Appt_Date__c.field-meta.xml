<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Agent_2_Appt_Date__c</fullName>
    <externalId>false</externalId>
    <formula>IF(ISBLANK(Agent_2_Appointment__c), "",
TEXT(DAY(DATEVALUE(Agent_2_Appointment__c))) &amp;
CASE(MOD(DAY(DATEVALUE(Agent_2_Appointment__c)), 10),
1, IF(DAY(DATEVALUE(Agent_2_Appointment__c)) = 11, "th", "st"),
2, IF(DAY(DATEVALUE(Agent_2_Appointment__c)) = 12, "th", "nd"),
3, IF(DAY(DATEVALUE(Agent_2_Appointment__c)) = 13, "th", "rd"),
"th") &amp; " " &amp;
CASE(MONTH(DATEVALUE(Agent_2_Appointment__c)),
1, "January", 2, "February", 3, "March", 4, "April",
5, "May", 6, "June", 7, "July", 8, "August",
9, "September", 10, "October", 11, "November", 12, "December", "") &amp;
" " &amp; TEXT(YEAR(DATEVALUE(Agent_2_Appointment__c))))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Agent 2 Appt Date</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
